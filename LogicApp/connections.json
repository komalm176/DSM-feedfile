{
    "serviceProviderConnections": {
        "serviceBus": {
            "parameterValues": {
                "connectionString": "@appsetting('SERVICE_BUS_CONNECTION_STRING')"
            },
            "serviceProvider": {
                "id": "/serviceProviders/serviceBus"
            },
            "displayName": "ServiceBus-FeedExport"
        },
        "azureBlob": {
            "parameterValues": {
                "connectionString": "@appsetting('BLOB_CONNECTION_STRING')"
            },
            "serviceProvider": {
                "id": "/serviceProviders/AzureBlob"
            },
            "displayName": "AzureBlob-FeedExport"
        },
        "sftp": {
            "parameterValues": {
                "hostName": "@appsetting('SFTP_HOST')",
                "port": "@appsetting('SFTP_PORT')",
                "userName": "@appsetting('SFTP_USERNAME')",
                "password": "@appsetting('SFTP_PASSWORD')",
                "sshPrivateKey": "",
                "sshPrivateKeyPassphrase": "",
                "acceptAnySshHostKey": true
            },
            "serviceProvider": {
                "id": "/serviceProviders/Sftp"
            },
            "displayName": "SFTP-FeedExport"
        }
    }
}
